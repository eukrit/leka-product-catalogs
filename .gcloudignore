# Cloud Build only needs medusa-backend/ + medusa-storefront/ + cloudbuild.yaml.
.git
.gcloudignore
.gitignore
.claude
.vscode
.tmp
node_modules
**/node_modules
**/.next
**/.tmp
**/__pycache__
*.pyc
*.log
*.zip
*.tar.gz
extracted_images
**/extracted_images
*Slack Downloads*
**/*Slack Downloads*
**/Slack Downloads*
/data
firestore
migration
/4soft
/4soft-catalog
/areda-catalog
/berliner-catalog
/eurotramp-catalog
/rampline-catalog
/vortex-catalog
/wisdom-catalog
# vinci-catalog/web-app/public/ is needed by the root Dockerfile (Flask
# serves /vinciplay/ from it). Exclude only the heavy non-runtime parts.
/vinci-catalog/scrape_catalog.py
/vinci-catalog/import_to_firestore.py
/vinci-catalog/import_pricelist.py
/vinci-catalog/firestore_schema.json
/vinci-catalog/data
# docs/ is mostly generated HTML not needed at runtime; only docs/forms/
# is needed for the Flask /forms/* routes.
/docs/architecture.html
/docs/build-summary.html
/docs/hub.html
/docs/BuildPlans
/docs/reports
/docs/summaries
/docs/*.md
# scripts/ + shared/: shared/ IS needed at runtime (src/main.py imports
# shared.pricing_config); scripts/ is not.
/scripts
**/build_output
**/dist
**/.cache
*.csv
*.xlsx
*.pdf
*.jpg
*.jpeg
*.png
*.webp
*.gif
*.md
# Keep storefront brand assets — needed by Next.js public/ folder.
!medusa-storefront/public/brands/**
PROJECT_INDEX.md
BUILD_LOG.md
CHANGELOG.md
README.md
verify.sh
manifest.example.json
requirements.txt
/package.json
/package-lock.json
