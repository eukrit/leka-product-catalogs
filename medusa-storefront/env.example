# Medusa Storefront Environment Variables
# Copy to .env.local and fill in values

NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_your_publishable_key_here

# Brand-specific publishable keys (scoped to Sales Channels)
NEXT_PUBLIC_WISDOM_PUBLISHABLE_KEY=pk_wisdom_key_here
NEXT_PUBLIC_VINCI_PUBLISHABLE_KEY=pk_vinci_key_here
