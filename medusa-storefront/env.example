# Medusa Storefront Environment Variables
# Copy to .env.local and fill in values

NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Brand-specific publishable keys (scoped to Sales Channels)
NEXT_PUBLIC_WISDOM_PUBLISHABLE_KEY=pk_wisdom_key_here
NEXT_PUBLIC_VINCI_PUBLISHABLE_KEY=pk_vinci_key_here
NEXT_PUBLIC_BERLINER_PUBLISHABLE_KEY=pk_berliner_key_here
NEXT_PUBLIC_EUROTRAMP_PUBLISHABLE_KEY=pk_eurotramp_key_here
NEXT_PUBLIC_RAMPLINE_PUBLISHABLE_KEY=pk_rampline_key_here
NEXT_PUBLIC_4SOFT_PUBLISHABLE_KEY=pk_4soft_key_here
