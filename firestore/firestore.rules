rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Per-brand product collections: products_wisdom, products_vinci, etc.
    match /{collection}/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Vendor quotations (all brands, filtered by brand/vendor_name fields)
    match /leka_vendor_quotations/{quotationId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
