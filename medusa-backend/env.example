# Medusa Backend Environment Variables
# Copy to .env and fill in values

# Database (Cloud SQL PostgreSQL) — REQUIRED
DATABASE_URL=postgresql://medusa:PASSWORD@localhost:5432/medusa

# Redis (Memorystore) — REQUIRED
REDIS_URL=redis://localhost:6379

# CORS origins — set to your actual domains in production
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:5173
AUTH_CORS=http://localhost:3000,http://localhost:5173

# Medusa
MEDUSA_BACKEND_URL=http://localhost:9000

# Secrets — REQUIRED, generate with: openssl rand -base64 32
COOKIE_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32

# GCP file storage — REQUIRED for production (local storage does not persist in containers)
# GCS_BUCKET=ai-agents-go-documents
# GCS_PREFIX=medusa-uploads
# GCS_ACCESS_KEY=your-gcs-hmac-access-key
# GCS_SECRET_KEY=your-gcs-hmac-secret-key

# Google OAuth (customer login) — optional; provider auto-registers when all
# three are set. SM secrets (production): medusa-google-oauth-client-id /
# -client-secret / -callback-url. The callback URL must also be registered on
# the Google OAuth Web client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://leka-medusa-backend-538978391890.asia-southeast1.run.app/auth/customer/google/callback

# Order notifications via data-communications routers (Rules 15/16).
# On order.placed the subscriber posts to Slack + emails a confirmation.
# Runtime SA must have run.invoker on these services AND be active in the
# slack_sender_allowlist / email_sender_allowlist Firestore collections.
DATA_COMMS_SEND_SLACK_URL=https://data-comms-send-slack-538978391890.asia-southeast1.run.app
DATA_COMMS_SEND_EMAIL_URL=https://data-comms-send-email-538978391890.asia-southeast1.run.app
ORDER_NOTIFY_EMAIL=leka-medusa-order@goco.bz
ORDER_NOTIFY_SLACK_CHANNEL=C0B557QQTDK
