{
  "compilerOptions": {
    "lib": ["es2021"],
    "target": "es2021",
    "outDir": ".medusa/server",
    "esModuleInterop": true,
    "declaration": true,
    "module": "es2022",
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "sourceMap": false,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", ".medusa", "dist"]
}
